<ui:FluentWindow x:Class="PhotoDownloader.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:views="clr-namespace:PhotoDownloader.Views"
                 x:Name="RootWindow"
                 Title="Загрузка изображений"
                 Height="580"
                 Width="1180"
                 MinHeight="560"
                 MinWidth="900"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{Binding Title, ElementName=RootWindow}"
                     ShowMinimize="True"
                     ShowMaximize="True"
                     ShowClose="True" />

        <Grid Grid.Row="1"
              Margin="16,8,16,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <views:ImageSlotView Grid.Column="0"
                                     Margin="7,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Top"
                                     DataContext="{Binding Slot1}" />
                <views:ImageSlotView Grid.Column="1"
                                     Margin="7,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Top"
                                     DataContext="{Binding Slot2}" />
                <views:ImageSlotView Grid.Column="2"
                                     Margin="7,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Top"
                                     DataContext="{Binding Slot3}" />
            </Grid>

            <StackPanel Grid.Row="1"
                        Margin="0,20,0,0"
                        VerticalAlignment="Bottom">
                <TextBlock Text="Общий прогресс"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ProgressBar Height="10"
                             Maximum="100"
                             Minimum="0"
                             Value="{Binding OverallProgress, Mode=OneWay}" />
                <DockPanel Margin="0,12,0,0" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Text="{Binding OverallStatusText}"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <ui:Button DockPanel.Dock="Right"
                               Content="Скачать все"
                               Command="{Binding DownloadAllCommand}"
                               Appearance="Primary"
                               MinWidth="140" />
                </DockPanel>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
